# ============================================================
# CREDENCIAIS: Fonte central em /home/cazouvilela/credenciais/
# NUNCA hardcodar credenciais aqui. Use referencia central.
# Loader bash: source /home/cazouvilela/credenciais/load-credentials.sh
# Loader node: require('/home/cazouvilela/credenciais/credentials.js')
# ============================================================
#
# Ambiente: PRODUCAO
# Projeto: framework_css
#
# ATENCAO: Este e o ambiente de producao com dados reais.
# Qualquer alteracao de schema/dados EXIGE backup previo.
# Qualquer deploy EXIGE commit previo e analise de impacto.

APP_ENV=prod
PREFIX=

# Banco de Dados (credenciais em /home/cazouvilela/credenciais/database/)
DB_NAME=framework_css
DB_HOST=localhost
DB_PORT=5432
DB_USER=prod_user
DB_PASSWORD=ALTERAR_OU_REFERENCIAR_CREDENCIAL_CENTRAL

# Servidor (este projeto so tem frontend)
FRONTEND_PORT=4200

# Services (systemd)
SERVICE_FRONTEND=framework-css
